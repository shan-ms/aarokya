# =============================================================
# Aarokya Docker Environment Variables
# Copy this file to .env and fill in production values.
# =============================================================

# ---- PostgreSQL ----
POSTGRES_DB=aarokya
POSTGRES_USER=aarokya
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_PORT=6379

# ---- Backend ----
BACKEND_PORT=8080
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64
JWT_EXPIRY_HOURS=24
RUST_LOG=aarokya_backend=info,actix_web=warn

# ---- Control Center ----
CONTROL_CENTER_PORT=3000
API_URL=http://backend:8080

# ---- Docker Image Config (production) ----
IMAGE_PREFIX=ghcr.io/your-org/aarokya
IMAGE_TAG=latest
